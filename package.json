{
  "name": "better-help",
  "displayName": "Better Help",
  "version": "0.0.2",
  "description": "A general purpose help tool for developers who write .js, .jsx, .ts. .tsx, .rs & more",
  "categories": [
    "cleaner",
    "productivity"
  ],
  "license": "MIT",
  "author": {
    "name": "Loi Tran",
    "email": "primetimetran@gmail.com",
    "url": "https://kb-blog-primetimetran.vercel.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/primetimetran/better-help"
  },
  "publisher": "primetimetran",
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js --bundle-build",
    "check-types": "tsc",
    "build": "node esbuild.js",
    "watch": "npm-run-all -p watch:esbuild watch:tsc",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch",
    "test": "vitest",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@babel/generator": "^7.29.7",
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.20.0",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "contributes": {
    "commands": [
      {
        "command": "better-help.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "better-help.registerCleanRust",
        "title": "Better Help: Clean Rust files of warnings including imports, exports, etc."
      },
      {
        "command": "better-help.normalizeClassNames",
        "title": "Better Help: Create single lines out of multi line JSX classNames"
      },
      {
        "command": "better-help.clean",
        "title": "Better Help: Clean JSX class name warnings, and normalize them to one line."
      },
      {
        "command": "better-help.alignTrailingComments",
        "title": "Better Help: Right Align Trailing comments."
      },
      {
        "command": "better-help.sortLines",
        "title": "Better Help: Sort selected lines"
      },
      {
        "command": "better-help.alignCSSBannerComments",
        "title": "Better Help: Align Trailing Comments in CSS"
      }
    ]
  },
  "engines": {
    "vscode": "^1.120.0"
  }
}
