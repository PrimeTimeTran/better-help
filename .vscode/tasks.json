{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch",
      "dependsOn": [
        "npm: watch:tsc",
        "npm: watch:esbuild"
      ],
      "group": { "kind": "build", "isDefault": true },
      "runOptions": { "runOn": "folderOpen" } 
    },
    {
      "type": "npm",
      "script": "watch:esbuild",
      "isBackground": true,
      "label": "npm: watch:esbuild",
      "problemMatcher": [],
      "presentation": { "group": "watch", "reveal": "always" }
    },
    {
      "type": "npm",
      "script": "watch:tsc",
      "isBackground": true,
      "label": "npm: watch:tsc",
      "problemMatcher": "$tsc-watch",
      "presentation": { "group": "watch", "reveal": "never" }
    }
  ]
}
