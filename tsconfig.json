{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",      
    "moduleResolution": "node",
    "esModuleInterop": true,
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "mocha", "vitest/globals"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "src/test/suite/suite.backup"],
  "exclude": ["node_modules", "dist"]
}
